---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { site } from '../data/site';
import { newsItems } from '../data/news';
import { researchPillars } from '../data/research';
import { projects } from '../data/projects';
import { acceptedPublications } from '../data/publications';
import { withBase } from '../utils/paths';

const latestNews = newsItems.slice(0, 4);
const featuredProjects = projects.filter((project) => project.status === 'active').slice(0, 3);
const recentPublications = acceptedPublications.slice(0, 4);

const formatNewsYear = (date: string) => date.match(/\d{4}/)?.[0] ?? date;
const localLink = (href: string) => href.startsWith('/') ? withBase(href) : href;
---

<AcademicLayout title="Home" description={site.description} activeNav="home">
  <main class="academic-content">
    <header class="academic-header">
      <div class="academic-header-grid">
        <h1 class="academic-name">{site.name}</h1>
        <p class="academic-title">{site.tagline}</p>
        <p class="academic-subtitle">{site.affiliation}</p>
        <p class="academic-meta">VinUniversity, Hanoi, Vietnam</p>
        <p class="academic-tagline">Robust, private, distributed, and efficient machine learning systems.</p>
        <div class="academic-social">
          {site.socialLinks.map((link) => link.url && <a class="academic-pill" href={link.url}>{link.label}</a>)}
          <a class="academic-pill" href={`mailto:${site.email}`}>Email</a>
        </div>
      </div>

      <div class="academic-bio">
        <p>
          <strong>SAIL</strong> is the Security and Artificial Intelligence Lab at VinUniversity. We study and build
          machine learning systems that are trustworthy, distributed across real-world settings, and efficient enough
          for practical deployment.
        </p>
        <p>
          The lab connects trustworthy AI, federated and distributed learning, privacy, robustness, backdoor attacks
          and defenses, edge AI, communication efficiency, and resource-aware machine learning.
        </p>
      </div>
    </header>

    <section class="academic-section">
      <h2 class="academic-section-title">Research</h2>
      <div class="academic-research-grid">
        {researchPillars.map((pillar) => (
          <article class="academic-card">
            <h3>{pillar.title}</h3>
            <p>{pillar.description}</p>
            <a class="academic-text-link" href={withBase(`/research/#${pillar.slug}`)}>Read more</a>
          </article>
        ))}
      </div>
    </section>

    <section class="academic-section">
      <div class="academic-section-heading-row">
        <h2 class="academic-section-title">News</h2>
        <a class="academic-text-link" href={withBase('/news/')}>All news</a>
      </div>
      <ul class="academic-news-list">
        {latestNews.map((item) => (
          <li class="academic-news-item">
            <span class="academic-news-date">{formatNewsYear(item.date)}</span>
            <span class="academic-news-text">
              <strong>{item.date}</strong>: {item.link ? <a href={localLink(item.link)}>{item.title}</a> : item.title}
              <span class="academic-news-label"> - {item.label}</span>
              <br />
              {item.summary}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <section class="academic-section">
      <div class="academic-section-heading-row">
        <h2 class="academic-section-title">Projects</h2>
        <a class="academic-text-link" href={withBase('/projects/')}>All projects</a>
      </div>
      <div class="academic-projects">
        {featuredProjects.map((project) => (
          <article class="academic-project" id={project.slug}>
            <h3>{project.title}</h3>
            <p>
              <strong>{project.pillar}</strong>{project.year ? `, ${project.year}` : ''}. {project.shortDescription}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="academic-section">
      <div class="academic-section-heading-row">
        <h2 class="academic-section-title">Recent Publications</h2>
        <a class="academic-text-link" href={withBase('/publications/')}>All publications</a>
      </div>
      <ul class="academic-publication-list compact">
        {recentPublications.map((publication) => (
          <li class="academic-publication-item">
            <span class="academic-publication-title">{publication.title}</span>
            <span class="academic-authors">
              <strong>{publication.authors[0]}</strong>{publication.authors.length > 1 ? `, ${publication.authors.slice(1).join(', ')}` : ''}
            </span>
            <span class="academic-venue">{publication.venue}, {publication.year}</span>
          </li>
        ))}
      </ul>
    </section>

  </main>
</AcademicLayout>
