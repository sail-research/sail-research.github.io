---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { site } from '../data/site';
import { projects } from '../data/projects';
import { acceptedPublications } from '../data/publications';
import { withBase } from '../utils/paths';

const featuredProjects = projects.filter((project) => project.status === 'active').slice(0, 3);
const recentPublications = acceptedPublications.slice(0, 4);
---

<AcademicLayout title="Home" description={site.description} activeNav="home">
  <main class="academic-content">
    <header class="academic-header">
      <div class="academic-header-grid">
        <h1 class="academic-name">{site.name}</h1>
        <p class="academic-title">{site.tagline}</p>
        <p class="academic-subtitle">{site.affiliation}</p>
        <p class="academic-meta">VinUniversity, Hanoi, Vietnam</p>
        <div class="academic-social">
          {site.socialLinks.map((link) => link.url && <a class="academic-pill" href={link.url}>{link.label}</a>)}
          <a class="academic-pill" href={`mailto:${site.email}`}>Email</a>
        </div>
      </div>

      <div class="academic-bio">
        <p>
          Our research group is situated within <a href="https://vinuni.edu.vn/college-of-engineering-computer-science/">VinUniversity's College of Engineering and Computer Science</a>.
          We specialize in trustworthy, distributed, and efficient AI, with a core focus on developing machine
          learning systems that remain robust, private, scalable, and practical in real-world settings. Our research
          encompasses federated learning, privacy-preserving machine learning, backdoor attacks and defenses,
          communication-efficient learning, edge AI, continual learning, and resource-aware AI to enhance security,
          privacy, reliability, efficiency, and fairness.
        </p>
      </div>
    </header>

    <section class="academic-section">
      <div class="academic-section-heading-row">
        <h2 class="academic-section-title">Projects</h2>
        <a class="academic-text-link" href={withBase('/projects/')}>All projects</a>
      </div>
      <div class="academic-projects">
        {featuredProjects.map((project) => (
          <article class="academic-project" id={project.slug}>
            <h3>{project.title}</h3>
            <p>
              <strong>{project.pillar}</strong>{project.year ? `, ${project.year}` : ''}. {project.shortDescription}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="academic-section">
      <div class="academic-section-heading-row">
        <h2 class="academic-section-title">Recent Publications</h2>
        <a class="academic-text-link" href={withBase('/publications/')}>All publications</a>
      </div>
      <ul class="academic-publication-list compact">
        {recentPublications.map((publication) => (
          <li class="academic-publication-item">
            <span class="academic-publication-title">{publication.title}</span>
            <span class="academic-authors">
              <strong>{publication.authors[0]}</strong>{publication.authors.length > 1 ? `, ${publication.authors.slice(1).join(', ')}` : ''}
            </span>
            <span class="academic-venue">{publication.venue}, {publication.year}</span>
          </li>
        ))}
      </ul>
    </section>

  </main>
</AcademicLayout>
