---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmptyState from '../components/EmptyState.astro';
---

<BaseLayout
  title="Team"
  description="The SAIL team directory is being updated."
  robots="noindex,nofollow"
>
  <section class="page-hero centered">
    <div class="container">
      <span class="kicker">Team</span>
      <h1 class="page-title mt-6"><span class="gradient-text">Team page under development.</span></h1>
      <p class="lead">The public directory is being updated and verified. Please check back soon.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <EmptyState
        title="Directory update in progress"
        message="Lab profiles are being collected through the private registration flow and will appear here after verification."
      />
    </div>
  </section>
</BaseLayout>
