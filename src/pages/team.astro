---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import AcademicTeamDirectory from '../components/AcademicTeamDirectory.astro';
---

<AcademicLayout title="Team" description="People at the Security and Artificial Intelligence Lab, VinUniversity." activeNav="team">
  <main class="academic-content">
    <header class="academic-page-header">
      <p class="academic-kicker">Team</p>
      <h1 class="academic-name">People behind SAIL.</h1>
      <p class="academic-section-intro">
        Faculty, students, research assistants, alumni, and collaborators in the SAIL research community.
      </p>
    </header>

    <section class="academic-section">
      <AcademicTeamDirectory />
    </section>
  </main>
</AcademicLayout>
