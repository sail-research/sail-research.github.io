---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { newsItems } from '../data/news';
import { withBase } from '../utils/paths';

const formatNewsYear = (date: string) => date.match(/\d{4}/)?.[0] ?? date;
const localLink = (href: string) => href.startsWith('/') ? withBase(href) : href;
---

<AcademicLayout title="News" description="SAIL news archive." activeNav="news">
  <main class="academic-content">
    <header class="academic-page-header">
      <p class="academic-kicker">News</p>
      <h1 class="academic-name">Lab updates.</h1>
      <p class="academic-section-intro">
        Recent papers, grants, professional service, and lab milestones.
      </p>
    </header>

    <section class="academic-section">
      <ul class="academic-news-list">
        {newsItems.map((item) => (
          <li class="academic-news-item">
            <span class="academic-news-date">{formatNewsYear(item.date)}</span>
            <span class="academic-news-text">
              <strong>{item.date}</strong>: {item.link ? <a href={localLink(item.link)}>{item.title}</a> : item.title}
              <span class="academic-news-label"> - {item.label}</span>
              <br />
              {item.summary}
            </span>
          </li>
        ))}
      </ul>
    </section>
  </main>
</AcademicLayout>
