---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import NewsStrip from '../components/NewsStrip.astro';
import { newsItems } from '../data/news';
---

<BaseLayout title="News" description="SAIL news archive.">
  <section class="page-hero">
    <div class="container">
      <span class="kicker">News</span>
      <h1 class="page-title mt-6"><span class="gradient-text">Lab updates archive.</span></h1>
      <p class="lead">News is intentionally kept outside the main navigation to preserve a minimal homepage and header.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <SectionHeader title="All updates" description="Edit this archive in src/data/news.ts." />
      <NewsStrip items={newsItems} showIntro={false} />
    </div>
  </section>
</BaseLayout>
