---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import NewsStrip from '../components/NewsStrip.astro';
import { newsItems } from '../data/news';
---

<BaseLayout title="News" description="SAIL news archive.">
  <section class="page-hero">
    <div class="container">
      <span class="kicker">News</span>
      <h1 class="page-title mt-6"><span class="gradient-text">Lab updates.</span></h1>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <NewsStrip items={newsItems} showIntro={false} />
    </div>
  </section>
</BaseLayout>
