---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { acceptedPublications, arxivPublications, type Publication } from '../data/publications';

const groupByYear = (items: Publication[]) =>
  items.reduce((groups, publication) => {
    if (!groups.has(publication.year)) groups.set(publication.year, []);
    groups.get(publication.year)?.push(publication);
    return groups;
  }, new Map<number, Publication[]>());

const acceptedByYear = groupByYear(acceptedPublications);
const arxivByYear = groupByYear(arxivPublications);
const firstLink = (links = []) => links[0]?.url;
const authorHtml = (authors: string[]) =>
  authors.map((author, index) => (index === 0 ? `<strong>${author}</strong>` : author)).join(', ');
---

<AcademicLayout title="Publications" description="Published and preprint research from the SAIL lab." activeNav="publications">
  <main class="academic-content">
    <header class="academic-page-header">
      <p class="academic-kicker">Publications</p>
      <h1 class="academic-name">Lab published papers.</h1>
      <p class="academic-section-intro">
        A curated publication list focused on trustworthy AI, federated learning, privacy, robustness, and efficient
        machine learning. First authors are highlighted.
      </p>
    </header>

    <section class="academic-section">
      <h2 class="academic-section-title">Accepted Papers</h2>
      {[...acceptedByYear.entries()].map(([year, items]) => (
        <div class="academic-year-group">
          <div class="academic-year">{year}</div>
          <ul class="academic-publication-list">
            {items.map((publication) => {
              const link = firstLink(publication.links);
              return (
                <li class="academic-publication-item">
                  {link ? (
                    <a class="academic-publication-title" href={link}>{publication.title}</a>
                  ) : (
                    <span class="academic-publication-title">{publication.title}</span>
                  )}
                  <span class="academic-authors" set:html={authorHtml(publication.authors)} />
                  <span class="academic-venue">
                    {publication.venue}, {publication.type}
                    {publication.venueMetric ? `, ${publication.venueMetric.label} (${publication.venueMetric.sourceYear}): ${publication.venueMetric.value}` : ''}
                  </span>
                  {publication.links && publication.links.length > 0 && (
                    <span class="academic-publication-links">
                      {publication.links.map((item) => <a href={item.url}>{item.label}</a>)}
                    </span>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </section>

    {arxivPublications.length > 0 && (
      <section class="academic-section">
        <h2 class="academic-section-title">arXiv Preprints</h2>
        {[...arxivByYear.entries()].map(([year, items]) => (
          <div class="academic-year-group">
            <div class="academic-year">{year}</div>
            <ul class="academic-publication-list">
              {items.map((publication) => {
                const link = firstLink(publication.links);
                return (
                  <li class="academic-publication-item">
                    {link ? (
                      <a class="academic-publication-title" href={link}>{publication.title}</a>
                    ) : (
                      <span class="academic-publication-title">{publication.title}</span>
                    )}
                    <span class="academic-authors" set:html={authorHtml(publication.authors)} />
                    <span class="academic-venue">{publication.venue}, {publication.type}</span>
                    {publication.links && publication.links.length > 0 && (
                      <span class="academic-publication-links">
                        {publication.links.map((item) => <a href={item.url}>{item.label}</a>)}
                      </span>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        ))}
      </section>
    )}
  </main>
</AcademicLayout>
