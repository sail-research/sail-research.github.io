---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const active = projects.filter((project) => project.status === 'active');
const completed = projects.filter((project) => project.status === 'completed');
const exploratory = projects.filter((project) => project.status === 'exploratory');
---

<BaseLayout title="Projects" description="Research projects from SAIL with placeholder figures for future visuals.">
  <section class="page-hero">
    <div class="container">
      <span class="kicker">Projects</span>
      <h1 class="page-title mt-6"><span class="gradient-text">Research in motion.</span></h1>
      <p class="lead">Projects connect the lab’s research pillars with concrete systems, benchmarks, and application areas. Every project currently uses a placeholder figure.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container stack">
      <SectionHeader title="Active projects" description="Current lines of work across trustworthy AI, distributed learning, and efficient machine learning." />
      {active.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  <section class="section-tight">
    <div class="container stack">
      <SectionHeader title="Completed projects" description="Completed projects remain visible to show the lab’s research history." />
      {completed.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

  {exploratory.length > 0 && (
    <section class="section">
      <div class="container stack">
        <SectionHeader title="Exploratory projects" />
        {exploratory.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  )}
</BaseLayout>
