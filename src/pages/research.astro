---
import AcademicLayout from '../layouts/AcademicLayout.astro';
import { researchPillars } from '../data/research';
import { projects } from '../data/projects';
import { acceptedPublications } from '../data/publications';
import { withBase } from '../utils/paths';
---

<AcademicLayout title="Research" description="SAIL research pillars: trustworthy AI, distributed learning, and efficient machine learning." activeNav="research">
  <main class="academic-content">
    <header class="academic-page-header">
      <p class="academic-kicker">Research</p>
      <h1 class="academic-name">Trustworthy, distributed, efficient.</h1>
      <p class="academic-section-intro">
        SAIL organizes its work around three connected pillars spanning AI security, privacy, federated systems,
        communication efficiency, and practical deployment.
      </p>
    </header>

    <section class="academic-section">
      <div class="academic-research-grid">
        {researchPillars.map((pillar) => (
          <article class="academic-card">
            <h3>{pillar.title}</h3>
            <p>{pillar.description}</p>
            <ul>
              {pillar.themes.slice(0, 5).map((theme) => <li>{theme}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    {researchPillars.map((pillar) => {
      const relatedProjects = projects.filter((project) => pillar.projectSlugs.includes(project.slug));
      const relatedPublications = acceptedPublications.filter((publication) =>
        publication.tags.some((tag) => pillar.publicationKeywords.includes(tag))
      ).slice(0, 4);

      return (
        <section class="academic-section" id={pillar.slug}>
          <h2 class="academic-section-title">{pillar.title}</h2>
          <p class="academic-section-intro">{pillar.description}</p>
          <div class="academic-two-column">
            <article>
              <h3 class="subsection-title">Representative Questions</h3>
              <ul class="academic-clean-list">
                {pillar.questions.map((question) => <li>{question}</li>)}
              </ul>
            </article>
            <article>
              <h3 class="subsection-title">Selected Publications</h3>
              <ul class="academic-link-list">
                {relatedPublications.map((publication) => (
                  <li><a href={withBase('/publications/')}>{publication.title}</a> <span>{publication.year}</span></li>
                ))}
              </ul>
            </article>
          </div>
          <div class="academic-projects">
            {relatedProjects.map((project) => (
              <article class="academic-project">
                <h3>{project.title}</h3>
                <p><strong>{project.pillar}</strong>. {project.shortDescription}</p>
              </article>
            ))}
          </div>
        </section>
      );
    })}
  </main>
</AcademicLayout>
