---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmptyState from '../components/EmptyState.astro';
---

<BaseLayout title="Gallery" description="SAIL gallery coming soon.">
  <section class="page-hero centered">
    <div class="container">
      <span class="kicker">Gallery</span>
      <h1 class="page-title mt-6">Coming soon.</h1>
      <div class="hero-note-grid">
        <p class="lead">A curated gallery for seminars, meetings, conference moments, and lab activities is being prepared.</p>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <EmptyState
        title="Gallery coming soon"
        message="Photos will be added after the lab image set is curated and approved."
      />
    </div>
  </section>
</BaseLayout>
