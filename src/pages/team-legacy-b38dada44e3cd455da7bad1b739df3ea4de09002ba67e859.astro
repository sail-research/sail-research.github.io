---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PersonCard from '../components/PersonCard.astro';
import EmptyState from '../components/EmptyState.astro';
import { getPeopleByGroup } from '../data/team';

const professors = getPeopleByGroup('professors');
const phd = getPeopleByGroup('phd');
const master = getPeopleByGroup('master');
const ras = getPeopleByGroup('research-assistants');
const undergradRas = getPeopleByGroup('undergraduate-ra');
const alumni = getPeopleByGroup('alumni');
const collaborators = getPeopleByGroup('collaborators');
---

<BaseLayout
  title="Team Legacy"
  description="Archived static SAIL team directory."
  robots="noindex,nofollow"
>
  <section class="page-hero">
    <div class="container">
      <span class="kicker">Legacy team view</span>
      <h1 class="page-title mt-6"><span class="gradient-text">People behind SAIL.</span></h1>
      <p class="lead">Archived static team directory kept for internal reference.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container stack">
      <SectionHeader title="Professors" description="" />
      <div class="person-grid">
        {professors.map((person) => <PersonCard person={person} showBio={false} showResearchInterests={false} showLinks={false} />)}
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <SectionHeader title="Graduate Students" description="" />
      <div class="tabs" role="tablist" aria-label="Graduate student groups">
        <button class="tab-button" type="button" role="tab" aria-selected="true" aria-controls="legacy-phd-panel" id="legacy-phd-tab" data-tab="legacy-phd-panel">PhD Students</button>
        <button class="tab-button" type="button" role="tab" aria-selected="false" aria-controls="legacy-master-panel" id="legacy-master-tab" data-tab="legacy-master-panel">Master Students</button>
      </div>
      <div id="legacy-phd-panel" class="tab-panel" role="tabpanel" aria-labelledby="legacy-phd-tab">
        <div class="person-grid">{phd.map((person) => <PersonCard person={person} />)}</div>
      </div>
      <div id="legacy-master-panel" class="tab-panel" role="tabpanel" aria-labelledby="legacy-master-tab" hidden>
        <div class="person-grid" hidden={master.length === 0}>{master.map((person) => <PersonCard person={person} />)}</div>
        <div data-empty-for="master" hidden={master.length > 0}>
          <EmptyState title="No Master students listed yet" message="This section will be updated when profiles are available." />
        </div>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <SectionHeader title="Research Assistants" description="" />
      <div class="tabs" role="tablist" aria-label="Research assistant groups">
        <button class="tab-button" type="button" role="tab" aria-selected="true" aria-controls="legacy-ra-panel" id="legacy-ra-tab" data-tab="legacy-ra-panel">Research Assistants</button>
        <button class="tab-button" type="button" role="tab" aria-selected="false" aria-controls="legacy-undergrad-ra-panel" id="legacy-undergrad-ra-tab" data-tab="legacy-undergrad-ra-panel">Undergraduate Student RAs</button>
      </div>
      <div id="legacy-ra-panel" class="tab-panel" role="tabpanel" aria-labelledby="legacy-ra-tab">
        <div class="person-grid">{ras.map((person) => <PersonCard person={person} />)}</div>
      </div>
      <div id="legacy-undergrad-ra-panel" class="tab-panel" role="tabpanel" aria-labelledby="legacy-undergrad-ra-tab" hidden>
        <div class="person-grid">{undergradRas.map((person) => <PersonCard person={person} />)}</div>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <SectionHeader title="Alumni" description="Former SAIL members and their current destinations where known." />
      <div class="person-grid">{alumni.map((person) => <PersonCard person={person} />)}</div>
    </div>
  </section>

  <section class="section" hidden>
    <div class="container">
      <SectionHeader title="Collaborators" description="" />
      <div class="person-grid" hidden={collaborators.length === 0}>{collaborators.map((person) => <PersonCard person={person} />)}</div>
      <div data-empty-for="collaborators" hidden={collaborators.length > 0}>
        <EmptyState title="Collaborators placeholder" message="This section will be updated when profiles are available." />
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.tabs').forEach((tabGroup) => {
      const buttons = Array.from(tabGroup.querySelectorAll('[data-tab]'));
      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          buttons.forEach((other) => other.setAttribute('aria-selected', String(other === button)));
          buttons.forEach((other) => {
            const panel = document.getElementById(other.dataset.tab);
            if (panel) panel.hidden = other !== button;
          });
        });
      });
    });
  </script>
</BaseLayout>
