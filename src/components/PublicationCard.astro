---
import type { Publication } from '../data/publications';
interface Props {
  publication: Publication;
}
const { publication } = Astro.props;

const authorText = publication.authors.join(', ');
const typeLabel = publication.type.charAt(0).toUpperCase() + publication.type.slice(1);
---

<article class="card pub-card">
  <div>
    <div class="flex flex-wrap gap-2 mb-3">
      <span class="chip chip-accent">{publication.venue}</span>
      <span class="chip">{typeLabel}</span>
      {publication.venueMetric && (
        <span class="chip chip-metric">{publication.venueMetric.label} ({publication.venueMetric.sourceYear}): {publication.venueMetric.value}</span>
      )}
    </div>
    <h3>{publication.title}</h3>
    <p class="pub-authors">{authorText}</p>
    <div class="pub-meta" aria-label="Publication tags">
      {publication.tags.map((tag) => <span class="chip">{tag}</span>)}
    </div>
    {publication.sourceNote && <p class="muted mt-3 text-sm">{publication.sourceNote}</p>}
    {publication.links && publication.links.length > 0 && (
      <div class="pub-links">
        {publication.links.map((link) => <a class="small-link" href={link.url} target="_blank" rel="noreferrer">{link.label}</a>)}
      </div>
    )}
  </div>
  <div class="pub-year" aria-label={`Publication year ${publication.year}`}>{publication.year}</div>
</article>
