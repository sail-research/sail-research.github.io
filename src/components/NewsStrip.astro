---
import type { NewsItem } from '../data/news';
import { withBase } from '../utils/paths';

interface Props {
  items: NewsItem[];
  showIntro?: boolean;
}

const { items, showIntro = false } = Astro.props;
---

<div class:list={['news-strip', showIntro && 'has-intro']}>
  {showIntro && (
    <aside class="news-intro">
      <span class="kicker">Latest</span>
      <h2>News from the lab</h2>
      <p>Paper acceptances, project launches, and professional service updates.</p>
      <a class="small-link" href={withBase('/news/')}>
        View all news <span aria-hidden="true">-&gt;</span>
      </a>
    </aside>
  )}

  <div class="news-list">
    {items.map((item) => (
      <article class="news-item">
        <div class="news-meta">
          <time>{item.date}</time>
          <span class="chip">{item.label}</span>
        </div>

        <div class="news-body">
          <h3>
            {item.link ? <a href={withBase(item.link)}>{item.title}</a> : item.title}
          </h3>

          <p>{item.summary}</p>
        </div>
      </article>
    ))}
  </div>
</div>

<style>
.news-strip {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.75rem;
}

.news-strip.has-intro {
  grid-template-columns: minmax(14rem, 0.36fr) minmax(0, 1fr);
  align-items: start;
}

.news-intro {
  position: sticky;
  top: calc(var(--header-height) + 1rem);
  padding: 1rem;
  border: 1px solid var(--border);
  border-radius: 1.1rem;
  background: rgba(255, 255, 255, 0.92);
}

.news-intro h2 {
  margin: 0.75rem 0 0;
  font-size: clamp(1.35rem, 3vw, 2rem);
  line-height: 1;
  letter-spacing: -0.04em;
}

.news-intro p {
  margin: 0.75rem 0 1rem;
  color: var(--muted);
  font-size: 0.92rem;
  line-height: 1.55;
}

.news-list {
  width: 100%;
  display: grid;
  gap: 0.7rem;
}

.news-item {
  width: 100%;
  display: grid;
  grid-template-columns: minmax(7.5rem, 0.18fr) minmax(0, 1fr);
  gap: 1rem;
  align-items: start;
  padding: 1rem;
  border: 1px solid var(--border);
  border-radius: 1rem;
  background:
    linear-gradient(135deg, rgba(26, 5, 162, 0.026), transparent 48%),
    #ffffff;
  transition: border-color 180ms ease, background 180ms ease, transform 180ms ease;
}

.news-item:hover {
  transform: translateY(-1px);
  border-color: rgba(26, 5, 162, 0.18);
  background:
    linear-gradient(135deg, rgba(26, 5, 162, 0.045), transparent 52%),
    #ffffff;
}

.news-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.5rem;
}

.news-item time {
  color: var(--accent);
  font-size: 0.76rem;
  font-weight: 850;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.news-item h3 {
  margin: 0;
  max-width: 58rem;
  font-size: clamp(1rem, 1.55vw, 1.25rem);
  line-height: 1.18;
  letter-spacing: -0.025em;
}

.news-item a:hover {
  color: var(--primary);
}

.news-item p {
  display: -webkit-box;
  margin: 0.42rem 0 0;
  color: var(--muted);
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 0.93rem;
  line-height: 1.55;
}

@media (max-width: 980px) {
  .news-strip.has-intro {
    grid-template-columns: 1fr;
  }

  .news-intro {
    position: static;
  }
}

@media (max-width: 680px) {
  .news-item {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  .news-meta {
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
  }
}
</style>
