---
import PlaceholderFigure from './PlaceholderFigure.astro';
import type { GalleryItem } from '../data/gallery';
interface Props {
  item: GalleryItem;
}
const { item } = Astro.props;
const style = `--panel-height:${item.height}px`;
---

<article class="card gallery-panel" style={style}>
  <PlaceholderFigure label={item.label} title={`Placeholder image for ${item.title}`} />
  <span class="gallery-label">{item.label}</span>
  <h3>{item.title}</h3>
  <p>{item.caption}</p>
</article>
