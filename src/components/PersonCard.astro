---
import type { Person } from '../data/team';
import { withBase } from '../utils/paths';
interface Props {
  person: Person;
  showBio?: boolean;
  showResearchInterests?: boolean;
  showLinks?: boolean;
}
const { person, showBio = true, showResearchInterests = true, showLinks = true } = Astro.props;
const imageSrc = person.image ? withBase(person.image) : undefined;
---

<article class="card person-card">
  <figure class:list={['avatar', imageSrc && 'has-image']}>
    {imageSrc ? (
      <img src={imageSrc} alt={person.name} decoding="async" />
    ) : (
      <span class="sr-only">{`Portrait placeholder for ${person.name}`}</span>
    )}
  </figure>
  <h3>{person.name}</h3>
  <div class="role">{person.role}</div>
  {person.affiliation && <p>{person.affiliation}</p>}
  {showBio && person.shortBio && <p>{person.shortBio}</p>}
  {showResearchInterests && person.researchInterests && person.researchInterests.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-4">
      {person.researchInterests.map((interest) => <span class="chip">{interest}</span>)}
    </div>
  )}
  {showLinks && person.links && person.links.length > 0 && (
    <div class="person-links">
      {person.links.map((link) => <a class="small-link" href={link.url}>{link.label}</a>)}
    </div>
  )}
</article>
